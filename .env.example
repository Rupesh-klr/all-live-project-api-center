# ── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────────
#
# Option A — Atlas SRV (simple, but needs DNS SRV support)
#   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
#
# Option B — Atlas Standard (use this if you get "querySrv ECONNREFUSED")
#   Get it from: Atlas → Cluster0 → Connect → Drivers → toggle "Standard connection string"
#   mongodb://<user>:<pass>@shard-00-00.<cluster>.mongodb.net:27017,shard-00-01.<cluster>.mongodb.net:27017,shard-00-02.<cluster>.mongodb.net:27017/<db>?ssl=true&replicaSet=<rs>&authSource=admin&retryWrites=true&w=majority
#
# Option C — Local MongoDB
#   mongodb://localhost:27017/portfolio_hub
#
# NOTE: special characters in password must be URL-encoded
#   space → %20   @ → %40   # → %23   $ → %24   + → %2B
#
MONGO_URI=

# ── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Encryption (shared with frontend — must be identical) ──
# AES passphrase used to decrypt ENCRY_MIDDLE_PROTECTION: prefixed fields
ENCRY_MIDDLE_KEY=change_me_32char_aes_passphrase!!

# ── Log viewer access (24-char key) ────────────────────────
LOG_ACCESS_KEY=change_me_24charLogAccessKey!!

# ── CORS allowed origins ────────────────────────────────────
# Comma-separated: exact origins + any *.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_MAIN_DOMAIN=yourdomain.com

# ── IP / Host whitelist (comma-separated, empty = allow all)
WHITELIST_IPS=
WHITELIST_HOSTS=

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── Identity (mirrors frontend src/config/app.config.js) ────
BRAND_NAME=portfolio.hub
DEVELOPER_NAME=Rupesh
DEVELOPER_TITLE=Full-Stack Engineer
PORTFOLIO_TAGLINE=Production-grade engineering
PORTFOLIO_EXPERIENCE=
CONTACT_EMAIL=

# ── Pagination defaults (shared by all modules) ─────────────
PAGINATION_DEFAULT_LIMIT=10
PAGINATION_MAX_LIMIT=100

# ── Telecom Optimizer (optional external Python compute) ────
# When set, the module bridges heavy graph ops to a Python FastAPI service.
# Leave blank to compute locally (demo always works offline).
TELECOM_PYTHON_URL=

# ── Profiles module — optional git backup of profile JSON ───
# OFF by default. When ON, a background job exports every profile to
# <repo>/profiles/<slug>.json and commits + pushes on an interval.
# PROFILE_GIT_DIR can be a LOCAL checked-out repo path, OR a remote https URL
# (auto-cloned into a cache dir). For an https URL, PROFILE_GIT_TOKEN is required
# to push (a GitHub personal access token with repo write access).
PROFILE_GIT_SYNC=true
PROFILE_GIT_DIR=https://github.com/Rupesh-klr/profile-rupesh-model
PROFILE_GIT_TOKEN=
PROFILE_GIT_BRANCH=main
PROFILE_GIT_SYNC_MINUTES=15
# PROFILE_GIT_CACHE=    # optional: where URL repos are cloned (default: OS temp)
# PROFILE_GIT_EMAIL=    # optional: commit author email
# PROFILE_GIT_NAME=     # optional: commit author name
# Profile-builder dev verification OTP (out of SMS/email credits → fixed code).
PROFILE_DEV_OTP=123123
# PROFILE_DEFAULT_RESET=123123   # password forgot-reset defaults to this
# JWT_PROFILE_EXPIRY=30d         # builder session length

# ── Real-estate module ──────────────────────────────────────
# Auto-mounted at /api/realstate/v1. Roles live on the shared User model:
#   super-admin / admin / vendor / user  (new signups default to "user").
# Seed the role hierarchy + sample listings once:  npm run seed:realstate
# REALSTATE_COMPANY_NAME=Estate Hub Realty   # optional — landing-page company name
